PROJECT_NAME=Medical Voice Agent Backend
ENVIRONMENT=local
API_V1_STR=/api/v1

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Clinic
CLINIC_TIMEZONE=America/Chicago
SCHEDULING_HORIZON_DAYS=14

# Vapi webhook secret (leave empty to skip verification)
VAPI_WEBHOOK_SECRET=

# Semantic triage (optional; requires backend/migrations/010_medical_knowledge_rag.sql)
OPENAI_API_KEY=
TRIAGE_SEMANTIC_SEARCH_ENABLED=false
TRIAGE_SEMANTIC_MATCH_COUNT=5
TRIAGE_SEMANTIC_MATCH_THRESHOLD=0.3
TRIAGE_SEMANTIC_SCORE_SCALE=2.0

# Frontend
FRONTEND_HOST=http://localhost:3000

BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
